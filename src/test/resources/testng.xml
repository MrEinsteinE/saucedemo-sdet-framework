<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">

<!--
    testng.xml — TestNG Suite Configuration
    
    Runs all tests in the framework. 
    To run only smoke tests: mvn test -Dgroups=smoke
    To run only regression:  mvn test -Dgroups=regression
    To run E2E only:         mvn test -Dgroups=e2e
-->
<suite name="SauceDemo SDET Automation Suite" verbose="1" parallel="false">

    <parameter name="browser" value="chrome"/>

    <!-- ═══════════════════════════════════════════════════════════
         SMOKE TEST RUN — Critical path (login + landing)
    ════════════════════════════════════════════════════════════ -->
    <test name="Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.sdet.tests.LoginTest"/>
            <class name="com.sdet.tests.InventoryTest"/>
            <class name="com.sdet.tests.CheckoutTest"/>
        </classes>
    </test>

    <!-- ═══════════════════════════════════════════════════════════
         REGRESSION TEST RUN — Full suite
    ════════════════════════════════════════════════════════════ -->
    <test name="Regression Tests">
        <groups>
            <run>
                <include name="regression"/>
                <exclude name="smoke"/>  <!-- smoke already ran above -->
            </run>
        </groups>
        <classes>
            <class name="com.sdet.tests.LoginTest"/>
            <class name="com.sdet.tests.InventoryTest"/>
            <class name="com.sdet.tests.CheckoutTest"/>
        </classes>
    </test>

</suite>
